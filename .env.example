# ── Stripe (Zahlung) ──────────────────────────────────────────────────────────
# Werte aus: dashboard.stripe.com → Developers → API keys
# Für Produktion: Live-Keys verwenden (pk_live_... / sk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook-Secret aus: dashboard.stripe.com → Developers → Webhooks → Endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Supabase (Datenbank) ─────────────────────────────────────────────────────
# Werte aus: supabase.com → Dein Projekt → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (E-Mail-Versand) ──────────────────────────────────────────────────
# API-Key aus: resend.com → API Keys → Create API Key
# Domain cam2rent.de muss in Resend verifiziert sein!
RESEND_API_KEY=re_...
FROM_EMAIL=buchungen@cam2rent.de
ADMIN_EMAIL=kontakt@cam2rent.de

# ── Admin-Zugang ─────────────────────────────────────────────────────────────
# Sicheres Passwort wählen! Wird für /admin/* Bereich verwendet.
ADMIN_PASSWORD=dein-sicheres-passwort-hier

# ── Sendcloud (Versand) ──────────────────────────────────────────────────────
# API-Keys aus: app.sendcloud.com → Einstellungen → API
SENDCLOUD_PUBLIC_KEY=
SENDCLOUD_SECRET_KEY=

# Absenderadresse für Versandetiketten
SENDCLOUD_SHIPPER_NAME=cam2rent
SENDCLOUD_SHIPPER_STREET=Deine Straße
SENDCLOUD_SHIPPER_HOUSE=1
SENDCLOUD_SHIPPER_ZIP=12345
SENDCLOUD_SHIPPER_CITY=Deine Stadt
SENDCLOUD_SHIPPER_COUNTRY=DE

# ── Optional ─────────────────────────────────────────────────────────────────
# Wartungsmodus (true = Seite zeigt Wartungsseite)
MAINTENANCE_MODE=false

# Geheimes Token für Cron-Jobs (daily-report, abandoned-cart)
CRON_SECRET=ein-zufaelliges-geheimes-token
