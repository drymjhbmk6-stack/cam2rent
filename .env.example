# ── Stripe (Zahlung) ──────────────────────────────────────────────────────────
# Werte aus: dashboard.stripe.com → Developers → API keys
# Für Produktion: Live-Keys verwenden (pk_live_... / sk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook-Secret aus: dashboard.stripe.com → Developers → Webhooks → Endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Supabase (Datenbank) ─────────────────────────────────────────────────────
# Werte aus: supabase.com → Dein Projekt → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (E-Mail-Versand) ──────────────────────────────────────────────────
# API-Key aus: resend.com → API Keys → Create API Key
# Domain cam2rent.de muss in Resend verifiziert sein!
RESEND_API_KEY=re_...
FROM_EMAIL=buchungen@cam2rent.de
ADMIN_EMAIL=kontakt@cam2rent.de

# ── Admin-Zugang ─────────────────────────────────────────────────────────────
# Sicheres Passwort wählen! Wird für /admin/* Bereich verwendet.
ADMIN_PASSWORD=dein-sicheres-passwort-hier

# ── Sendcloud (Versand) ──────────────────────────────────────────────────────
# API-Keys aus: app.sendcloud.com → Einstellungen → API
SENDCLOUD_PUBLIC_KEY=
SENDCLOUD_SECRET_KEY=

# Absenderadresse für Versandetiketten
SENDCLOUD_SHIPPER_NAME=cam2rent
SENDCLOUD_SHIPPER_STREET=Deine Straße
SENDCLOUD_SHIPPER_HOUSE=1
SENDCLOUD_SHIPPER_ZIP=12345
SENDCLOUD_SHIPPER_CITY=Deine Stadt
SENDCLOUD_SHIPPER_COUNTRY=DE

# ── Test-/Live-Modus (env-mode.ts) ───────────────────────────────────────────
# Optional: Doppelte Varianten von Stripe/Sendcloud/From-Email/Site-URL je
# Modus, gesteuert ueber admin_settings.environment_mode (siehe CLAUDE.md).
# Format: <NAME>_LIVE und <NAME>_TEST. Fallback ist die Variante ohne Suffix.
# Beispiele:
# STRIPE_SECRET_KEY_LIVE=sk_live_...
# STRIPE_SECRET_KEY_TEST=sk_test_...
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...
# STRIPE_WEBHOOK_SECRET_TEST=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
# SENDCLOUD_PUBLIC_KEY_LIVE=
# SENDCLOUD_PUBLIC_KEY_TEST=
# SENDCLOUD_SECRET_KEY_LIVE=
# SENDCLOUD_SECRET_KEY_TEST=
# FROM_EMAIL_LIVE=buchungen@cam2rent.de
# FROM_EMAIL_TEST=test@cam2rent.de
# NEXT_PUBLIC_SITE_URL_LIVE=https://cam2rent.de
# NEXT_PUBLIC_SITE_URL_TEST=https://test.cam2rent.de
NEXT_PUBLIC_SITE_URL=https://test.cam2rent.de

# Optional: Im Test-Modus alle Kundenmails an diese Adresse umleiten
# (Subject bekommt "[TEST → urspruenglich: ...]" Prefix).
TEST_MODE_REDIRECT_EMAIL=

# ── Push-Notifications (Admin-PWA, web-push) ─────────────────────────────────
# Generieren mit: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:kontakt@cam2rent.de

# ── Blog/Social/Reels KI ─────────────────────────────────────────────────────
# Optional: API-Keys koennen alternativ in admin_settings.blog_settings
# gepflegt werden. Env-Var hat Vorrang, falls beides gesetzt.
OPENAI_API_KEY=
# Pexels Stock-Footage fuer Reels (kostenlos: pexels.com/api)
PEXELS_API_KEY=

# ── Meta Graph API (Social-Posting Facebook + Instagram) ─────────────────────
# Aus developers.facebook.com → App → Settings → Basic
META_APP_ID=
META_APP_SECRET=

# ── Google Places API (Bewertungen auf Startseite) ───────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# ── Resend (separater Read-Key fuer Email-Log) ───────────────────────────────
# Optional: Read-only-Key fuer das Resend-Dashboard im Admin
RESEND_API_READ_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────
# Wartungsmodus (true = Seite zeigt Wartungsseite)
MAINTENANCE_MODE=false

# Geheimes Token fuer Cron-Jobs
CRON_SECRET=ein-zufaelliges-geheimes-token

# Optional Haertung: URL-Parameter-Auth fuer Crons deaktivieren
# (zwingt Cron-Jobs auf Header-Auth, damit Secrets nicht in Access-Logs landen)
CRON_DISABLE_URL_SECRET=false

# Reverse-Proxy-Vertrauen (X-Forwarded-For). Default in Production: true.
# Auf false setzen, wenn die App nicht hinter Coolify/nginx laeuft.
TRUST_PROXY_HEADERS=true
